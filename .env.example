OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemini-3.1-flash-lite-preview

# Listen address (default 127.0.0.1 = laptop only). On a Raspberry Pi, use 0.0.0.0 so
# phones on the same Wi-Fi can open http://<pi-ip>:3000 and use /stream + /api/lan-ipv4.
# RTT_ALHUDA_LISTEN_HOST=0.0.0.0
# RTT_ALHUDA_LISTEN_PORT=3000
# Extra OpenRouter request logs to the server terminal (no full API key printed):
# OPENROUTER_DEBUG=1

# Text-to-speech (OpenRouter POST /api/v1/tts)
# OPENROUTER_TTS_URL=https://openrouter.ai/api/v1/tts
# OPENROUTER_TTS_MODEL=openai/gpt-4o-mini-tts-2025-12-15
# OPENROUTER_TTS_VOICE_EN=alloy
# OPENROUTER_TTS_VOICE_HU=alloy
# OPENROUTER_TTS_RESPONSE_FORMAT=mp3   # valid: mp3, pcm

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite by default. For Postgres, set DATABASE_URL instead of KHUTBA_DB_PATH.
# KHUTBA_DB_PATH=/data/alhuda.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/khutba

# ── Multi-tenancy ────────────────────────────────────────────────────────────
# Slug of the default organization created on first run (superadmin belongs to it).
# KHUTBA_DEFAULT_ORG_SLUG=default

# ── Auth (required — no insecure defaults) ───────────────────────────────────
KHUTBA_ADMIN_EMAIL=admin@example.com
KHUTBA_ADMIN_PASSWORD=change-me-before-production
KHUTBA_JWT_SECRET=generate-a-long-random-string-at-least-32-chars
# Set to 1 when serving HTTPS (production):
# KHUTBA_COOKIE_SECURE=1

